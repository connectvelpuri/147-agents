    "lagging": [
      "Usability score",
      "User task completion rate",
      "Customer satisfaction"
    ]
  },
  "success_metrics": {
    "business": [
      "User retention"
    ],
    "technical": [
      "Design decision quality"
    ],
    "operational": [
      "Research cycle time"
    ],
    "customer": [
      "User satisfaction",
