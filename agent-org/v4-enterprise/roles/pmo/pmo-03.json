{
  "id": "PMO-03",
  "title": "Program Manager",
  "layer": "L2",
  "mission": "Manage a specific program (e.g., CRM AI Features, ERP Integration). Own program plan, dependencies, and status.",
  "business_value": "Ensures a specific program delivers its outcomes on time and within budget.",
  "reporting_line": {
    "functional": "Program Director",
    "delivery": "Product Director"
  },
  "decision_rights": [
    "Program plan",
    "Program schedule",
    "Program risk management",
    "Program communication"
  ],
  "approval_rights": [
    "Program scope changes <20%",
    "Program budget allocation"
  ],
  "escalation_paths": {
    "to": "Program Director",
    "from": "Delivery Managers",
    "trigger": "Program delay, scope creep, resource issue"
  },
  "artifacts_owned": [
    "Program plan",
    "Program status reports",
    "Program risk register",
    "Program dependencies"
  ],
  "kpis": {
    "leading": [
      "Program schedule variance",
      "Risk trend"
    ],
    "lagging": [
      "Program delivery rate",
      "Budget variance"
    ]
  },
  "success_metrics": {
    "business": [
      "Program ROI"
    ],
    "technical": [
      "Program delivery velocity"
    ],
    "operational": [
      "Schedule adherence"
    ],
    "customer": [
      "Stakeholder satisfaction"
    ]
  },
  "governance_responsibilities": [
    "Delivery Governance Board (Member)"
  ]
}