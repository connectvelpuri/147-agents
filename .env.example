# Revenue OS — Environment Configuration
# Copy to .env and fill in values

# LLM API Keys (at least one required for AI execution)
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# API Authentication (set a secure random key)
API_KEY=revenue-os-prod-2026

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Server
PORT=8080
HOST=0.0.0.0
